# Copy this file to .env (the repo ships a working .env for local dev already).
DATABASE_URL="postgresql://medibook:medibook@localhost:5432/medibook?schema=public"
JWT_SECRET="dev-secret-change-me"
PORT=4000

# Comma-separated list of browser origins allowed to call this API.
# Leave empty for local dev (any origin). REQUIRED in production — the server
# refuses to start without it when NODE_ENV=production.
# CORS_ORIGINS="https://azzamgm.github.io"

# How many reverse proxies sit in front of the API. Rate limiting reads the
# client IP through this many X-Forwarded-For hops, so an over-large value lets
# clients spoof their IP and bypass the limits.
TRUST_PROXY_HOPS=1
