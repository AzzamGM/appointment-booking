generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  STAFF
}

enum Specialty {
  GENERAL_PRACTICE
  PEDIATRICS
  DERMATOLOGY
  CARDIOLOGY
  ORTHOPEDICS
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SlotStatus {
  OPEN
  BOOKED
  BLOCKED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(PATIENT)
  phone        String?
  createdAt    DateTime @default(now())

  doctorProfile Doctor?

  appointments       Appointment[]  @relation("PatientAppointments")
  bookedAppointments Appointment[]  @relation("BookedByUser")
  prescriptions      Prescription[] @relation("PrescribedBy")
  auditLogs          AuditLog[]
}

model Clinic {
  id        String @id @default(cuid())
  code      String @unique
  name      String
  nameAr    String?
  address   String
  addressAr String?
  city      String
  cityAr    String?
  phone     String

  doctors        DoctorClinic[]
  availabilities Availability[]
  slots          Slot[]
}

model Doctor {
  id        String    @id @default(cuid())
  userId    String?   @unique
  user      User?     @relation(fields: [userId], references: [id])
  name      String
  nameAr    String?
  specialty Specialty
  bio       String?
  bioAr     String?

  clinics        DoctorClinic[]
  availabilities Availability[]
  timeOff        TimeOff[]
  slots          Slot[]

  @@index([specialty])
}

model DoctorClinic {
  doctorId String
  clinicId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@id([doctorId, clinicId])
  @@index([clinicId])
}

model Service {
  id               String      @id @default(cuid())
  name             String      @unique
  nameAr           String?
  durationMinutes  Int
  price            Decimal     @db.Decimal(10, 2)
  requiresApproval Boolean     @default(false)
  specialties      Specialty[]

  appointments Appointment[]
}

model Availability {
  id        String @id @default(cuid())
  doctorId  String
  clinicId  String
  doctor    Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic    Clinic @relation(fields: [clinicId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String

  @@unique([doctorId, clinicId, dayOfWeek, startTime])
}

model TimeOff {
  id       String   @id @default(cuid())
  doctorId String
  doctor   Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  startAt  DateTime
  endAt    DateTime
  reason   String?

  @@index([doctorId, startAt])
}

model Slot {
  id       String     @id @default(cuid())
  doctorId String
  clinicId String
  doctor   Doctor     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic   Clinic     @relation(fields: [clinicId], references: [id])
  startAt  DateTime
  endAt    DateTime
  status   SlotStatus @default(OPEN)

  appointments Appointment[]

  @@unique([doctorId, startAt])
  @@index([doctorId, status, startAt])
}

model Appointment {
  id        String            @id @default(cuid())
  reference String            @unique
  status    AppointmentStatus @default(REQUESTED)

  patientId String?
  patient   User?   @relation("PatientAppointments", fields: [patientId], references: [id])
  slotId    String
  slot      Slot    @relation(fields: [slotId], references: [id])
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  bookedById String?
  bookedBy   User?   @relation("BookedByUser", fields: [bookedById], references: [id])

  guestName  String?
  guestEmail String?
  guestPhone String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prescriptions Prescription[]

  @@index([patientId, createdAt])
  @@index([slotId])
}

model Prescription {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  medication   String
  dosage       String
  frequency    String
  instructions String?

  prescribedById String
  prescribedBy   User     @relation("PrescribedBy", fields: [prescribedById], references: [id])
  createdAt      DateTime @default(now())

  @@index([appointmentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}
