{
  "name": "clinic-appointments",
  "private": true,
  "version": "0.1.0",
  "description": "Full-stack medical clinic appointment system — a backend learning project with intentional gaps. See LEARNING_GUIDE.md.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w frontend",
    "db:up": "docker compose up -d",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "test": "npm run test -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "prisma@6.19.3": true
  }
}
